<Window x:Class="X4StationBuilder.App.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:h="http://helix-toolkit.org/wpf"
        mc:Ignorable="d"
        Title="3D Station Preview" Height="720" Width="960">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#444" BorderThickness="1">
            <h:HelixViewport3D x:Name="Viewport"
                               ShowCoordinateSystem="True"
                               ShowFrameRate="True"
                               ZoomExtentsWhenLoaded="True"
                               Background="#202020">
                <h:DefaultLights/>
                <h:GridLinesVisual3D x:Name="GroundGrid" Width="60" Length="60"
                                     MinorDistance="6" MajorDistance="30" Thickness="0.05"
                                     Fill="#555"/>
            </h:HelixViewport3D>
        </Border>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Summary}" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Production" Foreground="#4285F4" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Storage" Foreground="#F4B400" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Dock" Foreground="#E53935" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="Habitat" Foreground="#43A047" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <CheckBox Content="Labels" IsChecked="{Binding ShowLabels}"
                          VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button Content="Refresh" Command="{Binding RefreshCommand}"
                        Padding="14,6" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
